{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "properties": {
    "general": {
      "properties": {
        "default_environment": {
          "type": "string"
        },
        "mouse_enabled": {
          "type": "boolean"
        }
      },
      "type": "object"
    },
    "history": {
      "properties": {
        "compression_threshold": {
          "type": "integer"
        },
        "enabled": {
          "type": "boolean"
        },
        "level": {
          "type": "string"
        },
        "path": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "presets": {
      "items": {
        "properties": {
          "environment": {
            "type": "string"
          },
          "flags": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "name": {
            "type": "string"
          },
          "theme": {
            "type": "string"
          },
          "workdir": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "array"
    },
    "project_overrides": {
      "additionalProperties": {
        "properties": {
          "flags": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "preset_name": {
            "type": "string"
          },
          "theme": {
            "type": "string"
          }
        },
        "type": "object"
      },
      "type": "object"
    },
    "terraform": {
      "properties": {
        "binary": {
          "type": "string"
        },
        "default_flags": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "parallelism": {
          "type": "integer"
        },
        "timeout": {
          "type": "string"
        },
        "working_dir": {
          "type": "string"
        }
      },
      "type": "object"
    },
    "theme": {
      "properties": {
        "name": {
          "type": "string"
        }
      },
      "type": "object"
    }
  },
  "title": "lazytf config",
  "type": "object"
}
